generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model group_members {
  id        Int                 @id @default(autoincrement())
  group_id  Int
  user_id   Int
  role      group_members_role? @default(member)
  joined_at DateTime?           @default(now()) @db.Timestamp(0)
  groups    groups              @relation(fields: [group_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "group_members_ibfk_1")
  users     users               @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "group_members_ibfk_2")

  @@unique([group_id, user_id], map: "unique_membership")
  @@index([user_id], map: "user_id")
}

model groups {
  id                             Int                           @id @default(autoincrement())
  name                           String                        @db.VarChar(255)
  description                    String?                       @default("") @db.VarChar(1000)
  avatar                         String?                       @db.MediumText
  created_by                     Int
  owner_id                       Int
  message_permission             groups_message_permission?    @default(all)
  add_member_permission          groups_add_member_permission? @default(everyone)
  allow_member_leave             Boolean?                      @default(true)
  slow_mode                      Boolean?                      @default(false)
  slow_mode_seconds              Int?                          @default(10)
  created_at                     DateTime?                     @default(now()) @db.Timestamp(0)
  group_members                  group_members[]
  users_groups_created_byTousers users                         @relation("groups_created_byTousers", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "groups_ibfk_1")
  users_groups_owner_idTousers   users                         @relation("groups_owner_idTousers", fields: [owner_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "groups_ibfk_2")

  @@index([created_by], map: "created_by")
  @@index([owner_id], map: "owner_id")
}

model message_reactions {
  id         Int       @id @default(autoincrement())
  message_id Int
  user_id    Int
  emoji      String    @db.VarChar(20)
  created_at DateTime? @default(now()) @db.Timestamp(0)
  messages   messages  @relation(fields: [message_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "message_reactions_ibfk_1")
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "message_reactions_ibfk_2")

  @@unique([message_id, user_id, emoji], map: "unique_reaction")
  @@index([user_id], map: "user_id")
}

model messages {
  id                Int                 @id @default(autoincrement())
  conversation_id   String              @db.VarChar(100)
  content           String              @db.Text
  sender_id         Int
  type              messages_type?      @default(text)
  reply_to          Int?
  is_deleted        Boolean?            @default(false)
  deleted_by        Int?
  deleted_at        DateTime?           @db.Timestamp(0)
  edited_at         DateTime?           @db.Timestamp(0)
  created_at        DateTime?           @default(now()) @db.Timestamp(0)
  message_reactions message_reactions[]
  users             users               @relation(fields: [sender_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "messages_ibfk_1")

  @@index([conversation_id], map: "idx_conversation")
  @@index([created_at], map: "idx_created_at")
  @@index([sender_id], map: "sender_id")
}

model notification_reads {
  notification_id Int
  user_id         Int
  read_at         DateTime?     @default(now()) @db.Timestamp(0)
  notifications   notifications @relation(fields: [notification_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "notification_reads_ibfk_1")
  users           users         @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "notification_reads_ibfk_2")

  @@id([notification_id, user_id])
  @@index([user_id], map: "user_id")
}

model notifications {
  id                 Int                  @id @default(autoincrement())
  type               String               @default("info") @db.VarChar(50)
  recipient_id       Int?
  title              String               @db.VarChar(255)
  body               String               @db.VarChar(1000)
  created_at         DateTime?            @default(now()) @db.Timestamp(0)
  notification_reads notification_reads[]
}

// Session Management
model user_sessions {
  id                String    @id @default(cuid())
  user_id           Int
  token_hash        String    @db.VarChar(255)
  device_info       String?   @db.VarChar(500)
  ip_address        String?   @db.VarChar(45)
  user_agent        String?   @db.Text
  is_active         Boolean   @default(true)
  login_at          DateTime  @default(now()) @db.Timestamp(0)
  last_activity     DateTime  @default(now()) @db.Timestamp(0)
  expires_at        DateTime  @db.Timestamp(0)
  logged_out_at     DateTime?
  users             users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id])
  @@index([expires_at])
  @@index([token_hash])
}

// Token Blacklist for Revocation
model token_blacklist {
  id           Int       @id @default(autoincrement())
  token_hash   String    @unique @db.VarChar(255)
  user_id      Int
  blacklist_at DateTime  @default(now()) @db.Timestamp(0)
  expires_at   DateTime  @db.Timestamp(0)

  @@index([user_id])
  @@index([expires_at])
}

// User Settings Persistence
model user_settings {
  id                   Int       @id @default(autoincrement())
  user_id              Int       @unique
  theme                String    @default("system") @db.VarChar(20)
  compact_mode         Boolean   @default(false)
  message_density      String    @default("comfortable") @db.VarChar(20)
  sidebar_collapsed    Boolean   @default(false)
  notifications_enabled Boolean  @default(true)
  sound_enabled        Boolean   @default(true)
  notification_sound   String    @default("default") @db.VarChar(20)
  desktop_notifications Boolean  @default(true)
  mute_all             Boolean   @default(false)
  online_status_visible Boolean  @default(true)
  typing_indicator     Boolean   @default(true)
  read_receipts        Boolean   @default(true)
  last_seen_visible    Boolean   @default(true)
  auto_play_videos     Boolean   @default(false)
  auto_play_gifs       Boolean   @default(true)
  preview_links        Boolean   @default(true)
  date_format          String    @default("12h") @db.VarChar(10)
  language             String    @default("en") @db.VarChar(10)
  timezone             String    @default("UTC") @db.VarChar(50)
  debug_mode           Boolean   @default(false)
  updated_at           DateTime  @default(now()) @updatedAt @db.Timestamp(0)
  users                users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id])
}

// Message Read Tracking
model message_reads {
  id         Int       @id @default(autoincrement())
  message_id Int
  user_id    Int
  read_at    DateTime  @default(now()) @db.Timestamp(0)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([message_id, user_id])
  @@index([user_id])
  @@index([read_at])
}

// Message Deliveries Tracking
model message_deliveries {
  id           Int       @id @default(autoincrement())
  message_id   Int
  user_id      Int
  delivered_at DateTime  @default(now()) @db.Timestamp(0)
  users        users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([message_id, user_id])
  @@index([message_id])
  @@index([user_id])
  @@index([delivered_at])
}

// Last Seen Per Conversation
model conversation_last_seen {
  id              Int       @id @default(autoincrement())
  conversation_id String    @db.VarChar(100)
  user_id         Int
  last_seen_at    DateTime  @default(now()) @db.Timestamp(0)
  last_message_id Int?
  updated_at      DateTime  @default(now()) @updatedAt @db.Timestamp(0)
  users           users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([conversation_id, user_id])
  @@index([user_id])
}

// File Metadata & Tracking
model file_metadata {
  id              String    @id @default(cuid())
  r2_key          String    @unique @db.VarChar(500)
  conversation_id String    @db.VarChar(100)
  user_id         Int
  original_name   String    @db.VarChar(255)
  file_type       String    @db.VarChar(20)
  mime_type       String    @db.VarChar(100)
  file_size       BigInt
  uploaded_at     DateTime  @default(now()) @db.Timestamp(0)
  users           users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([conversation_id])
  @@index([user_id])
  @@index([uploaded_at])
}

// Conversation Metadata (mute, pin, block, hidden)
model conversation_metadata {
  id              Int       @id @default(autoincrement())
  conversation_id String    @db.VarChar(100)
  user_id         Int
  is_muted        Boolean   @default(false)
  muted_until     DateTime?
  is_pinned       Boolean   @default(false)
  is_blocked      Boolean   @default(false)
  is_hidden       Boolean   @default(false)
  updated_at      DateTime  @default(now()) @updatedAt @db.Timestamp(0)
  users           users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([conversation_id, user_id])
  @@index([user_id])
}


model users {
  id                              Int                     @id @default(autoincrement())
  name                            String                  @db.VarChar(100)
  email                           String                  @unique(map: "email") @db.VarChar(150)
  password                        String                  @db.VarChar(255)
  role                            users_role              @default(user)
  avatar                          String?                 @db.Text
  status                          users_status            @default(offline)
  department                      String?                 @default("") @db.VarChar(100)
  is_active                       Boolean                 @default(true)
  created_at                      DateTime?               @default(now()) @db.Timestamp(0)
  updated_at                      DateTime?               @default(now()) @db.Timestamp(0)
  group_members                   group_members[]
  groups_groups_created_byTousers groups[]                @relation("groups_created_byTousers")
  groups_groups_owner_idTousers   groups[]                @relation("groups_owner_idTousers")
  message_reactions               message_reactions[]
  messages                        messages[]
  message_deliveries              message_deliveries[]
  notification_reads              notification_reads[]
  user_sessions                   user_sessions[]
  user_settings                   user_settings[]
  message_reads                   message_reads[]
  file_metadata                   file_metadata[]
  conversation_last_seen          conversation_last_seen[]
  conversation_metadata           conversation_metadata[]
}

enum group_members_role {
  member
  admin
  owner
}

enum messages_type {
  text
  file
  system
  image
  video
}

enum users_role {
  admin
  user
}

enum groups_message_permission {
  all
  admin_only
}

enum users_status {
  online
  away
  offline
  dnd
}

enum groups_add_member_permission {
  admin_only
  everyone
}
