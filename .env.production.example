# Production deployment configuration values.

MYSQL_ROOT_PASSWORD=ChangeMeRoot123!
DB_NAME=teams_app
DB_USER=teams_user
DB_PASSWORD=ChangeMeDBPass123!
DB_HOST=db
DB_PORT=3306
DATABASE_URL=mysql://teams_user:ChangeMeDBPass123!@db:3306/teams_app

JWT_SECRET=replace-with-a-strong-production-secret
JWT_EXPIRES_IN=1h
ALLOWED_ORIGINS=https://your-production-domain.com
BASE_URL=https://your-production-domain.com
NEXT_PUBLIC_API_URL=https://your-production-domain.com/api

# Optional object storage / file persistence
R2_BUCKET_NAME=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Local upload persistence root (Docker volume: backend_uploads)
UPLOAD_ROOT=/app/uploads
